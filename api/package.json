{
  "name": "api",
  "version": "0.0.1",
  "description": "api service for CRIA project",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/app.ts",
    "build": "tsc -p . && tsc-alias",
    "start": "node --env-file-if-exists=.env dist/app.js",
    "test": "jest",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "tsc-alias": "^1.8.8",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
